generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FOUNDER
  FRONTEND
  BACKEND
  DEVOPS
  AI_ML
}

enum PostCategory {
  BUG
  IMPROVEMENT
  SUGGESTION
  FEATURE
  IDEA
  DISCUSSION
}

enum PostStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  passwordHash  String
  name          String         @unique
  avatarUrl     String?
  bio           String?
  role          Role
  createdAt     DateTime       @default(now())

  posts         Post[]         @relation("AuthorPosts")
  assignedPosts Post[]         @relation("AssigneePosts")
  comments      Comment[]
  reactions     Reaction[]
  notifications Notification[]
}

model Post {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  category    PostCategory
  status      PostStatus   @default(OPEN)
  priority    Priority     @default(MEDIUM)
  tags        String[]     @default([])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  authorId    Int
  author      User         @relation("AuthorPosts", fields: [authorId], references: [id])
  assigneeId  Int?
  assignee    User?        @relation("AssigneePosts", fields: [assigneeId], references: [id])

  comments    Comment[]
  reactions   Reaction[]
  attachments Attachment[]
}

model Comment {
  id        Int        @id @default(autoincrement())
  content   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  authorId  Int
  author    User       @relation(fields: [authorId], references: [id])
  postId    Int
  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId  Int?
  parent    Comment?   @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[]  @relation("Replies")

  reactions Reaction[]
}

model Reaction {
  id        Int      @id @default(autoincrement())
  emoji     String   @default("👍")

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  postId    Int?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId Int?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, emoji])
  @@unique([userId, commentId, emoji])
}

model Attachment {
  id       Int    @id @default(autoincrement())
  url      String
  filename String
  mimeType String
  postId   Int
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}
